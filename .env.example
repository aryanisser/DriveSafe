# Copy to .env for local dev, or set these in Render / Hugging Face Secrets

# Gmail App Password (Google Account → Security → 2-Step Verification → App Passwords)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=aryanisser@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
ALERT_EMAIL=aryanisser@gmail.com

# Optional: GitHub release URLs for model weights (if not bundled in repo)
GITHUB_WEIGHTS_REPO=thearyanisser/DriveSafe-Road-crack-detection-system
GITHUB_WEIGHTS_RELEASE_TAG=v1.0.0
